# Database
DATABASE_URL="postgresql://nextgen_user:password@localhost:5432/nextgen_erp"

# For Docker Compose PostgreSQL service
POSTGRES_USER=nextgen_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=nextgen_erp

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_api_key_here"

# Business Info (shown in UI)
NEXT_PUBLIC_APP_NAME="Your Business Name"
NEXT_PUBLIC_PAN="your_pan_number"
NEXT_PUBLIC_PHONE="your_phone_number"
NEXT_PUBLIC_ADDRESS="Your Business Address"
